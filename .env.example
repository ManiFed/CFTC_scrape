# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/cftc_pipeline

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Storage (local for dev, set to "s3" for prod)
STORAGE_BACKEND=local
STORAGE_BASE_PATH=./data

# S3 (if STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET=cftc-pipeline-raw

# Scraper
REQUEST_DELAY_SECONDS=1.0
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRIES=3

# LLM
LLM_MODEL=claude-opus-4-6
LLM_MAX_TOKENS=4096
PROMPT_VERSION=v1

# Pipeline
LOG_LEVEL=INFO
